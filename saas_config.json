{
  "saas_backend": {
    "base_url": "http://localhost:8001",

    "endpoints": {
      "get_all_zones": {
        "method": "GET",
        "path": "/api/zones",
        "description": "Get all zones with current status"
      },
      "get_zone": {
        "method": "GET",
        "path": "/api/zones/{zone_id}",
        "description": "Get a single zone by ID"
      },
      "set_temperature": {
        "method": "POST",
        "path": "/api/zones/{zone_id}/temperature",
        "description": "Set target temperature for a zone",
        "body": {
          "temperature": "number",
          "changed_by": "string"
        }
      },
      "set_mode": {
        "method": "POST",
        "path": "/api/zones/{zone_id}/mode",
        "description": "Set mode (cooling/heating/auto/off)",
        "body": {
          "mode": "string",
          "changed_by": "string"
        }
      },
      "set_status": {
        "method": "POST",
        "path": "/api/zones/{zone_id}/status",
        "description": "Turn zone on or off",
        "body": {
          "status": "string",
          "changed_by": "string"
        }
      },
      "get_zone_logs": {
        "method": "GET",
        "path": "/api/zones/{zone_id}/logs",
        "description": "Get activity logs for a zone"
      },
      "login": {
        "method": "POST",
        "path": "/api/auth/login",
        "description": "User login",
        "body": {
          "email": "string",
          "password": "string"
        }
      },
      "signup": {
        "method": "POST",
        "path": "/api/auth/signup",
        "description": "User registration",
        "body": {
          "name": "string",
          "email": "string",
          "password": "string"
        }
      }
    },

    "zone_map": {
      "bedroom": "bedroom",
      "bed room": "bedroom",
      "master bedroom": "bedroom",
      "kitchen": "kitchen",
      "hall": "hall",
      "living room": "hall",
      "living hall": "hall",
      "office": "office",
      "home office": "office",
      "study": "office"
    }
  }
}